---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/blocks/PageHeader.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import InfoBox from '../components/ui/InfoBox.astro';
import Placeholder from '../components/ui/Placeholder.astro';
import Testimonials from '../components/blocks/Testimonials.astro';
import CtaBanner from '../components/blocks/CtaBanner.astro';

const packages = [
  {
    title: 'Příprava pleti',
    subtitle: 'Balíček 3 ošetření',
    description: 'Série tří specializovaných kosmetických ošetření pro dokonalou přípravu pleti. Hydratace, vyhlazení a rozzáření — přesně to, co Vaše pleť před velkým dnem potřebuje.',
    price: '3 500 Kč',
    includes: ['3× kosmetické ošetření Larens', 'Vstupní konzultace a plán péče', 'Doporučení domácí péče', 'Zvýhodněná cena balíčku'],
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Svatební vizáž',
    subtitle: 'Líčení vč. zkoušky',
    description: 'Profesionální svatební líčení s přípravou pleti. Zahrnuje zkušební líčení pro nalezení ideálního výsledku a samotné líčení v den svatby.',
    price: 'od 3 500 Kč',
    includes: ['Zkouška líčení předem', 'Příprava pleti v den svatby', 'Dlouhotrvající make-up', 'Kosmetika Larens Colour'],
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  {
    title: 'Kompletní vizáž',
    subtitle: 'Make-up + účes',
    description: 'Kompletní proměna — profesionální svatební líčení i účes v jednom. Budete zářit od prvního tance až do posledního.',
    price: 'od 4 500 Kč',
    includes: ['Zkouška make-upu i účesu', 'Příprava pleti', 'Svatební líčení', 'Svatební účes'],
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
];

const timeline = [
  {
    period: '3 měsíce před',
    title: 'Konzultace a zahájení péče',
    desc: 'Vstupní konzultace, analýza pleti, nastavení plánu péče. Ideální čas pro zahájení série ošetření.',
  },
  {
    period: '6–8 týdnů před',
    title: 'Zkouška vizáže',
    desc: 'Zkouška líčení a případně účesu. Najdeme společně ideální výsledek a zaznamenáme každý krok.',
  },
  {
    period: '1 týden před',
    title: 'Poslední ošetření',
    desc: 'Závěrečné hydratační ošetření pro maximální zářivost pleti. Žádné agresivní procedury.',
  },
  {
    period: 'Den D',
    title: 'Příprava a vizáž',
    desc: 'Příprava pleti, profesionální líčení a účes. Budete připraveni přivítat svůj velký den.',
  },
];

const faq = [
  {
    q: 'Kdy mám začít s přípravou pleti?',
    a: 'Ideálně 3 měsíce před svatbou. To je dost času na sérii ošetření, jejichž výsledky jsou dlouhodobé a viditelné.',
  },
  {
    q: 'Musím přijít na zkoušku vizáže?',
    a: 'Ano, zkouška je součástí každého balíčku. Společně najdeme ideální výsledek, zaznamenáme postup a v den svatby bude vše přesné.',
  },
  {
    q: 'Jak dlouho trvá líčení v den svatby?',
    a: 'Samotné líčení trvá přibližně 90 minut, s přípravou pleti počítejte s 2 hodinami. S účesem 2,5–3,5 hodiny.',
  },
  {
    q: 'Líčíte i svědkyni nebo maminku?',
    a: 'Ano, ráda se postarám i o Vaše doprovody. Domluvme se na termínu a počtu osob předem.',
  },
];
---

<Layout
  title="Pro nevěsty"
  description="Svatební kosmetika a vizáž — JANESKIN Dolní Lutyně. Příprava pleti, svatební líčení se zkouškou, kompletní vizáž (make-up + účes). Jana Szymiková."
>
  <PageHeader
    label="Svatební den"
    title="Váš velký den začíná u nás"
    subtitle="Připravím Vaši pleť i vizáž na den, na který celý život čekáte — s péčí, precizností a radostí."
    breadcrumb={[{ label: 'Pro nevěsty', href: '/pro-nevesty' }]}
  />

  <!-- Intro -->
  <section class="brides-intro section" aria-label="Úvod">
    <div class="brides-intro__inner container">
      <div class="brides-intro__text">
        <p class="brides-intro__lead">
          Připravím Vaši pleť na velký den od základu — od kosmetických ošetření
          až po svatební líčení a účes, které vydrží do rána.
        </p>
        <p>
          Věřím, že krásná nevěsta je především spokojená a uvolněná nevěsta.
          Proto ke každé přípravě přistupuji s maximální péčí a klíčem k úspěchu
          je pro mě naše spolupráce — čím víc mi řeknete o svých přáních,
          tím lepší výsledek společně dosáhneme.
        </p>
        <div class="brides-intro__tip">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Ideálně začněte 3 měsíce před svatbou.
        </div>
      </div>
      <div class="brides-intro__image">
        <Placeholder aspect="3/4" label="Fotografie svatební vizáže" />
      </div>
    </div>
  </section>

  <!-- Balíčky -->
  <section class="brides-packages section section--alt" id="balicky" aria-label="Svatební balíčky">
    <div class="container">
      <SectionHeading
        label="Balíčky"
        title="Vyberte si svůj balíček"
        subtitle="Každý balíček lze přizpůsobit Vašim potřebám. Ráda Vám poradím, co bude pro Vás nejlepší."
      />

      <ul class="packages-grid" role="list">
        {packages.map(pkg => (
          <li>
            <Card variant="info">
              <div class="pkg-card__icon" aria-hidden="true" set:html={pkg.icon} />
              <div>
                <p class="pkg-card__subtitle">{pkg.subtitle}</p>
                <h3 class="pkg-card__title">{pkg.title}</h3>
              </div>
              <p class="pkg-card__desc">{pkg.description}</p>
              <ul class="pkg-card__includes" role="list">
                {pkg.includes.map(item => (
                  <li class="pkg-card__includes-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <div class="pkg-card__footer">
                <Badge text={pkg.price} variant="gold" />
                <Button href="#kontakt" variant="text" size="sm">Rezervovat</Button>
              </div>
            </Card>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Timeline -->
  <section class="timeline section" aria-label="Jak to probíhá">
    <div class="container">
      <SectionHeading
        label="Postup"
        title="Jak příprava probíhá"
        subtitle="Průvodce od první konzultace až po Váš velký den."
      />

      <ol class="timeline__list" role="list">
        {timeline.map((step, i) => (
          <li class="timeline__item">
            <div class="timeline__number" aria-hidden="true">{i + 1}</div>
            <div class="timeline__content">
              <p class="timeline__period">{step.period}</p>
              <h3 class="timeline__title">{step.title}</h3>
              <p class="timeline__desc">{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Galerie placeholder -->
  <section class="gallery section section--alt" aria-label="Ukázky práce">
    <div class="container">
      <SectionHeading
        label="Ukázky"
        title="Výsledky hovoří samy za sebe"
        subtitle="Fotografie svatebních vizáží budou doplněny."
      />
      <div class="gallery__grid" aria-label="Galerie svatebních vizáží">
        {Array.from({ length: 6 }).map((_, i) => (
          <Placeholder aspect="3/4" label={`Svatební vizáž ${i + 1}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq section" aria-label="Časté otázky">
    <div class="container">
      <SectionHeading
        label="FAQ"
        title="Časté otázky"
        subtitle="Odpovědi na nejčastější dotazy nevěst."
      />
      <dl class="faq__list">
        {faq.map(item => (
          <div class="faq__item">
            <dt class="faq__question">{item.q}</dt>
            <dd class="faq__answer">{item.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <Testimonials />
  <CtaBanner />
</Layout>

<style>
  /* Intro */
  .brides-intro__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .brides-intro__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .brides-intro__lead {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.4;
  }

  .brides-intro__text p:not(.brides-intro__lead):not(.brides-intro__tip) {
    font-size: var(--text-lg);
    color: var(--color-text-soft);
    line-height: 1.7;
  }

  .brides-intro__tip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-accent-hover);
    background-color: var(--color-accent-light);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
  }

  /* Packages */
  .packages-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .pkg-card__icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-accent-light);
    border-radius: var(--radius-md);
    color: var(--color-accent-hover);
  }

  .pkg-card__subtitle {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    font-weight: var(--weight-medium);
    margin-bottom: var(--space-1);
  }

  .pkg-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.2;
  }

  .pkg-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    line-height: 1.65;
    flex: 1;
  }

  .pkg-card__includes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pkg-card__includes-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  .pkg-card__includes-item svg {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .pkg-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  /* Timeline */
  .timeline__list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    counter-reset: timeline;
    position: relative;
  }

  .timeline__list::before {
    content: '';
    position: absolute;
    top: 22px;
    left: calc(22px + var(--space-6));
    right: calc(22px + var(--space-6));
    height: 2px;
    background: linear-gradient(to right, var(--color-accent-light), var(--color-accent), var(--color-accent-light));
  }

  .timeline__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    position: relative;
  }

  .timeline__number {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    background-color: var(--color-accent);
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    box-shadow: 0 0 0 4px var(--color-bg);
  }

  .timeline__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .timeline__period {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    font-weight: var(--weight-medium);
  }

  .timeline__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
  }

  .timeline__desc {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    line-height: 1.6;
  }

  /* Gallery */
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  /* FAQ */
  .faq__list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .faq__item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq__question {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-white);
    cursor: default;
  }

  .faq__answer {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    line-height: 1.7;
    padding: 0 var(--space-6) var(--space-5);
    background-color: var(--color-white);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .timeline__list {
      grid-template-columns: repeat(2, 1fr);
    }
    .timeline__list::before {
      display: none;
    }
    .packages-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .brides-intro__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .brides-intro__image {
      max-width: 340px;
      margin: 0 auto;
    }
    .packages-grid {
      grid-template-columns: 1fr;
    }
    .timeline__list {
      grid-template-columns: 1fr;
    }
    .timeline__item {
      align-items: flex-start;
      text-align: left;
      flex-direction: row;
      gap: var(--space-4);
    }
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .gallery__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
