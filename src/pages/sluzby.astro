---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/blocks/PageHeader.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import InfoBox from '../components/ui/InfoBox.astro';
import Equipment from '../components/blocks/Equipment.astro';
import Larens from '../components/blocks/Larens.astro';
import CtaBanner from '../components/blocks/CtaBanner.astro';
import services from '../data/services.json';

const categories = [
  {
    id: 'pece-o-plet',
    label: 'Péče o pleť',
    ids: ['kosmeticka-pece', 'chemicke-peelingy', 'microneedling', 'anti-spot'],
  },
  {
    id: 'masaze-a-relaxace',
    label: 'Masáže a relaxace',
    ids: ['masaze'],
  },
  {
    id: 'oci-a-obrvi',
    label: 'Oči a obočí',
    ids: ['laminace'],
  },
  {
    id: 'vizazistika',
    label: 'Vizážistika',
    ids: ['makeup'],
  },
  {
    id: 'doplnkove',
    label: 'Doplňkové služby',
    ids: ['doplnkove'],
  },
];

const serviceIcons: Record<string, string> = {
  'kosmeticka-pece': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  'chemicke-peelingy': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-5 0V4.5A2.5 2.5 0 0 1 9.5 2z"/><path d="M14.5 8A2.5 2.5 0 0 1 17 10.5v9a2.5 2.5 0 0 1-5 0v-9A2.5 2.5 0 0 1 14.5 8z"/></svg>`,
  'microneedling': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
  'anti-spot': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
  'masaze': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 11a3 3 0 0 0-3-3H9.5A3.5 3.5 0 0 0 6 11.5V17a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-6z"/><path d="M10 8V6a2 2 0 1 1 4 0v2"/></svg>`,
  'laminace': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`,
  'makeup': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  'doplnkove': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
};
---

<Layout
  title="Služby"
  description="Přehled všech kosmetických služeb salonu JANESKIN — ošetření pleti Larens, chemické peelingy, microneedling, masáže, laminace řas a obočí, vizážistika. Dolní Lutyně."
>
  <PageHeader
    label="Nabídka"
    title="Služby & Ceník"
    subtitle="Všechna ošetření přizpůsobuji stavu Vaší pleti a individuálním potřebám. Pracuji výhradně s kosmeceutikou Larens."
    breadcrumb={[{ label: 'Služby', href: '/sluzby' }]}
  />

  <!-- Kategorie navigace -->
  <div class="services-nav">
    <div class="container">
      <ul class="services-nav__list" role="list">
        {categories.map(cat => (
          <li>
            <a href={`#${cat.id}`} class="services-nav__link">{cat.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Kategorie se službami -->
  {categories.map(cat => {
    const catServices = services.filter(s => cat.ids.includes(s.id));
    return (
      <section class="services-section section" id={cat.id} aria-label={cat.label}>
        <div class="container">
          <SectionHeading
            label="Kategorie"
            title={cat.label}
            align="left"
          />
          <ul class="services-grid" role="list">
            {catServices.map(service => (
              <li>
                <Card variant="service">
                  <div class="service-icon" aria-hidden="true" set:html={serviceIcons[service.id]} />
                  <h3 class="service-title">{service.title}</h3>
                  <p class="service-desc">{service.description}</p>
                  <div class="service-meta">
                    <Badge text={`od ${service.priceFrom}`} variant="gold" />
                    <Badge text={service.duration} variant="subtle" />
                  </div>
                </Card>
              </li>
            ))}
          </ul>
        </div>
      </section>
    );
  })}

  <!-- Nutrivi sekce -->
  <section class="nutrivi-strip section section--alt" id="nutrivi" aria-label="Doplňky Nutrivi">
    <div class="container">
      <SectionHeading
        label="Doplňky stravy"
        title="Nutrivi — krása zevnitř"
        subtitle="Prémiové doplňky stravy na bázi přírodních peptidů a rostlinných extraktů. Ideální doplněk ke kosmetické péči."
      />
      <div class="nutrivi-strip__features">
        <InfoBox
          title="Zdraví kloubů a pohybového aparátu"
          text="Podpora přirozené regenerace a pohyblivosti."
          icon={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`}
        />
        <InfoBox
          title="Krása pleti, vlasů a nehtů"
          text="Výživa z hloubky pro viditelné výsledky."
          icon={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`}
        />
        <InfoBox
          title="Imunita a celková regenerace"
          text="Přírodní peptidy a rostlinné extrakty pro vitalitu."
          icon={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`}
        />
      </div>
      <div class="nutrivi-strip__cta">
        <Button href="#kontakt" variant="primary" size="md">Zeptat se na Nutrivi</Button>
      </div>
    </div>
  </section>

  <Equipment />
  <Larens />
  <CtaBanner />
</Layout>

<style>
  /* Category nav */
  .services-nav {
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 72px;
    z-index: calc(var(--z-header) - 1);
  }

  .services-nav__list {
    list-style: none;
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .services-nav__list::-webkit-scrollbar {
    display: none;
  }

  .services-nav__link {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-soft);
    text-decoration: none;
    padding: var(--space-4) var(--space-5);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .services-nav__link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* Services grid */
  .services-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .service-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-accent-light);
    border-radius: var(--radius-md);
    color: var(--color-accent-hover);
    flex-shrink: 0;
  }

  .service-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.2;
  }

  .service-desc {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    line-height: 1.65;
    flex: 1;
  }

  .service-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-2);
  }

  /* Nutrivi strip */
  .nutrivi-strip__features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .nutrivi-strip__cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    .nutrivi-strip__features {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
