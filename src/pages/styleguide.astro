---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import Card from '../components/ui/Card.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import InfoBox from '../components/ui/InfoBox.astro';
import Placeholder from '../components/ui/Placeholder.astro';
import Container from '../components/ui/Container.astro';

const colors = [
  { name: '--color-bg',           hex: '#FBF8F4', label: 'Pozadí' },
  { name: '--color-bg-alt',       hex: '#F3EDE5', label: 'Pozadí alt' },
  { name: '--color-text',         hex: '#2C2420', label: 'Text' },
  { name: '--color-text-soft',    hex: '#6B5D4F', label: 'Text soft' },
  { name: '--color-accent',       hex: '#C9A96E', label: 'Accent' },
  { name: '--color-accent-hover', hex: '#B8963E', label: 'Accent hover' },
  { name: '--color-accent-light', hex: '#E8D9B8', label: 'Accent light' },
  { name: '--color-white',        hex: '#FFFFFF', label: 'Bílá' },
  { name: '--color-border',       hex: '#E5DDD3', label: 'Border' },
];

const typeScale = [
  { token: '--text-xs',   size: '0.75rem',  px: '12px',  label: 'XS — popisky' },
  { token: '--text-sm',   size: '0.875rem', px: '14px',  label: 'SM — labely, meta' },
  { token: '--text-base', size: '1rem',     px: '16px',  label: 'BASE — tělo textu' },
  { token: '--text-lg',   size: '1.125rem', px: '18px',  label: 'LG — zvýrazněný text' },
  { token: '--text-xl',   size: '1.25rem',  px: '20px',  label: 'XL — podnadpisy' },
  { token: '--text-2xl',  size: '1.5rem',   px: '24px',  label: '2XL — H4' },
  { token: '--text-3xl',  size: '1.875rem', px: '30px',  label: '3XL — H3' },
  { token: '--text-4xl',  size: '3rem',     px: '48px',  label: '4XL — H2' },
  { token: '--text-5xl',  size: '4rem',     px: '64px',  label: '5XL — H1 desktop' },
  { token: '--text-6xl',  size: '3.75rem',  px: '60px',  label: '6XL — Hero nadpis' },
];

const spacing = [
  { token: '--space-1',  val: '0.25rem', px: '4px'  },
  { token: '--space-2',  val: '0.5rem',  px: '8px'  },
  { token: '--space-3',  val: '0.75rem', px: '12px' },
  { token: '--space-4',  val: '1rem',    px: '16px' },
  { token: '--space-5',  val: '1.25rem', px: '20px' },
  { token: '--space-6',  val: '1.5rem',  px: '24px' },
  { token: '--space-8',  val: '2rem',    px: '32px' },
  { token: '--space-10', val: '2.5rem',  px: '40px' },
  { token: '--space-12', val: '3rem',    px: '48px' },
  { token: '--space-16', val: '4rem',    px: '64px' },
  { token: '--space-20', val: '5rem',    px: '80px' },
  { token: '--space-24', val: '6rem',    px: '96px' },
];

const radii = [
  { token: '--radius-sm',   val: '6px'    },
  { token: '--radius-md',   val: '8px'    },
  { token: '--radius-lg',   val: '14px'   },
  { token: '--radius-xl',   val: '20px'   },
  { token: '--radius-full', val: '9999px' },
];

const shadows = [
  { token: '--shadow-sm',         label: 'SM'         },
  { token: '--shadow-md',         label: 'MD'         },
  { token: '--shadow-lg',         label: 'LG'         },
  { token: '--shadow-card',       label: 'Card'       },
  { token: '--shadow-card-hover', label: 'Card hover' },
];

const iconSample = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`;
---

<Layout title="Styleguide" noIndex={true}>

  <div class="sg-wrap">

    <!-- ══════════════════════════════════════
         HEADER
    ═══════════════════════════════════════ -->
    <div class="sg-page-header">
      <div class="sg-page-header__inner container">
        <div>
          <p class="sg-eyebrow">JANESKIN</p>
          <h1 class="sg-page-title">Design System & Styleguide</h1>
          <p class="sg-page-sub">Přehled všech tokenů, typografie, komponent a variant. Stránka není indexována.</p>
        </div>
        <nav class="sg-toc" aria-label="Obsah">
          <a href="#colors">Barvy</a>
          <a href="#typography">Typografie</a>
          <a href="#spacing">Spacing</a>
          <a href="#radius">Radius</a>
          <a href="#shadows">Stíny</a>
          <a href="#header">Hlavní menu</a>
          <a href="#buttons">Tlačítka</a>
          <a href="#badges">Badge</a>
          <a href="#cards">Karty</a>
          <a href="#photo-cards">Foto karty</a>
          <a href="#carousel-arrows">Šipky karuselu</a>
          <a href="#headings">SectionHeading</a>
          <a href="#infobox">InfoBox</a>
          <a href="#checklist">Checklist</a>
          <a href="#placeholder">Placeholder</a>
          <a href="#footer">Patička</a>
        </nav>
      </div>
    </div>

    <div class="sg-body container">

      <!-- ══════════════════════════════════════
           HLAVNÍ MENU
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="header">
        <h2 class="sg-section-title">Hlavní menu</h2>
        <p class="sg-section-desc">
          Fixní header (<code>position: fixed</code>) s dvěma stavy — výchozí (nad fotkou) a scrollovaný.
          Živá podoba je viditelná v horní části stránky ↑
        </p>
        <div class="sg-footer-tokens">
          <div class="sg-token-row">
            <span class="sg-token-label">Výška</span>
            <span class="sg-token-value">72px</span>
          </div>
          <div class="sg-token-row">
            <span class="sg-token-label">Výchozí pozadí</span>
            <span class="sg-token-value">transparent</span>
          </div>
          <div class="sg-token-row">
            <span class="sg-token-label">Výchozí border-bottom</span>
            <span class="sg-token-value">1px solid rgba(255, 255, 255, 0.08)</span>
          </div>
          <div class="sg-token-row">
            <span class="sg-token-label">Scrollovaný – pozadí</span>
            <span class="sg-token-value">rgba(251, 248, 244, 0.92) + backdrop-filter: blur(12px)</span>
          </div>
          <div class="sg-token-row">
            <span class="sg-token-label">Scrollovaný – border-bottom</span>
            <span class="sg-token-value"><code>var(--color-border)</code></span>
          </div>
          <div class="sg-token-row">
            <span class="sg-token-label">Logo výchozí</span>
            <span class="sg-token-value">filter: brightness(0) invert(1) — bílá</span>
          </div>
          <div class="sg-token-row">
            <span class="sg-token-label">Logo scrollovaný</span>
            <span class="sg-token-value">filter: none — originální barvy</span>
          </div>
          <div class="sg-token-row">
            <span class="sg-token-label">CTA tlačítko výchozí</span>
            <span class="sg-token-value">transparent + border rgba(255,255,255,0.75)</span>
          </div>
          <div class="sg-token-row">
            <span class="sg-token-label">CTA tlačítko scrollovaný</span>
            <span class="sg-token-value"><code>var(--color-accent)</code> fill</span>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════
           BARVY
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="colors">
        <h2 class="sg-section-title">Barvy</h2>
        <div class="sg-colors">
          {colors.map(c => (
            <div class="sg-color">
              <div
                class="sg-color__swatch"
                style={`background:${c.hex}; ${c.hex === '#FFFFFF' ? 'border: 1px solid var(--color-border);' : ''}`}
              ></div>
              <p class="sg-color__label">{c.label}</p>
              <p class="sg-color__token">{c.name}</p>
              <p class="sg-color__hex">{c.hex}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- ══════════════════════════════════════
           TYPOGRAFIE
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="typography">
        <h2 class="sg-section-title">Typografie</h2>

        <div class="sg-subsection">
          <h3 class="sg-subsection-title">Rodiny písem</h3>
          <div class="sg-fonts">
            <div class="sg-font-card">
              <p class="sg-font-card__name">Playfair Display</p>
              <p class="sg-font-card__token">--font-heading · weight 500</p>
              <p class="sg-font-card__sample sg-font-card__sample--heading">
                Aa Bb Cc Dd Ee<br />
                JANESKIN — Kosmetický salon<br />
                <em>Kurzíva pro elegantní akcenty</em>
              </p>
            </div>
            <div class="sg-font-card">
              <p class="sg-font-card__name">DM Sans</p>
              <p class="sg-font-card__token">--font-body · weight 400 / 500</p>
              <p class="sg-font-card__sample sg-font-card__sample--body">
                Aa Bb Cc Dd Ee<br />
                Profesionální kosmetická péče s kosmeceutikou Larens.<br />
                <strong>Tučný text pro důraz.</strong>
              </p>
            </div>
          </div>
        </div>

        <div class="sg-subsection">
          <h3 class="sg-subsection-title">Nadpisy (Playfair Display 500)</h3>
          <div class="sg-type-headings">
            <div class="sg-type-row">
              <span class="sg-type-meta">H1 · 5xl · 64px</span>
              <h1 class="sg-demo-h1">Péče o Vaši pleť s láskou</h1>
            </div>
            <div class="sg-type-row">
              <span class="sg-type-meta">H2 · 4xl · 48px</span>
              <h2 class="sg-demo-h2">Co pro Vás mohu udělat</h2>
            </div>
            <div class="sg-type-row">
              <span class="sg-type-meta">H3 · 3xl · 30px</span>
              <h3 class="sg-demo-h3">Kosmetická péče Larens</h3>
            </div>
            <div class="sg-type-row">
              <span class="sg-type-meta">H4 · 2xl · 24px</span>
              <h4 class="sg-demo-h4">Microneedling s Exosomy</h4>
            </div>
          </div>
        </div>

        <div class="sg-subsection">
          <h3 class="sg-subsection-title">Škála velikostí (DM Sans)</h3>
          <div class="sg-type-scale">
            {typeScale.map(t => (
              <div class="sg-type-scale-row">
                <span class="sg-type-meta">{t.token} · {t.px}</span>
                <span style={`font-size: ${t.size}; font-family: var(--font-body); color: var(--color-text);`}>
                  {t.label} — Jana Szymiková
                </span>
              </div>
            ))}
          </div>
        </div>

        <div class="sg-subsection">
          <h3 class="sg-subsection-title">Utility třídy</h3>
          <div class="sg-type-utils">
            <p class="label">Label — uppercase, tracking</p>
            <p class="text-soft">text-soft — tlumená barva textu</p>
            <p class="text-accent">text-accent — zlatá barva</p>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════
           SPACING
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="spacing">
        <h2 class="sg-section-title">Spacing (4px grid)</h2>
        <div class="sg-spacing">
          {spacing.map(s => (
            <div class="sg-spacing-row">
              <code class="sg-spacing-token">{s.token}</code>
              <span class="sg-spacing-val">{s.px}</span>
              <div class="sg-spacing-bar" style={`width: ${s.px}; min-width: 4px;`}></div>
            </div>
          ))}
        </div>
      </section>

      <!-- ══════════════════════════════════════
           BORDER RADIUS
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="radius">
        <h2 class="sg-section-title">Border Radius</h2>
        <div class="sg-radii">
          {radii.map(r => (
            <div class="sg-radius-item">
              <div class="sg-radius-box" style={`border-radius: ${r.val};`}></div>
              <code class="sg-radius-token">{r.token}</code>
              <span class="sg-radius-val">{r.val}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ══════════════════════════════════════
           STÍNY
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="shadows">
        <h2 class="sg-section-title">Stíny</h2>
        <div class="sg-shadows">
          {shadows.map(s => (
            <div class="sg-shadow-item">
              <div class="sg-shadow-box" style={`box-shadow: var(${s.token});`}></div>
              <code class="sg-shadow-token">{s.token}</code>
              <span class="sg-shadow-label">{s.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ══════════════════════════════════════
           BUTTONS
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="buttons">
        <h2 class="sg-section-title">Tlačítka</h2>

        <div class="sg-subsection">
          <h3 class="sg-subsection-title">Varianty</h3>
          <div class="sg-row sg-row--wrap">
            <Button variant="primary" size="md">Primary</Button>
            <Button variant="outline" size="md">Outline</Button>
            <Button variant="text" size="md">Text</Button>
          </div>
        </div>

        <div class="sg-subsection">
          <h3 class="sg-subsection-title">Velikosti (primary)</h3>
          <div class="sg-row sg-row--wrap sg-row--baseline">
            <Button variant="primary" size="sm">Small</Button>
            <Button variant="primary" size="md">Medium</Button>
            <Button variant="primary" size="lg">Large</Button>
          </div>
        </div>

        <div class="sg-subsection">
          <h3 class="sg-subsection-title">Velikosti (outline)</h3>
          <div class="sg-row sg-row--wrap sg-row--baseline">
            <Button variant="outline" size="sm">Small</Button>
            <Button variant="outline" size="md">Medium</Button>
            <Button variant="outline" size="lg">Large</Button>
          </div>
        </div>

        <div class="sg-subsection">
          <h3 class="sg-subsection-title">Jako odkaz (href)</h3>
          <div class="sg-row sg-row--wrap">
            <Button href="#" variant="primary" size="md">Objednat se</Button>
            <Button href="#" variant="outline" size="md">Více informací</Button>
            <Button href="#" variant="text" size="md">Zobrazit ceník</Button>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════
           BADGES
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="badges">
        <h2 class="sg-section-title">Badge</h2>
        <div class="sg-row sg-row--wrap">
          <Badge text="od 1 100 Kč" variant="gold" />
          <Badge text="60 min" variant="subtle" />
          <Badge text="Zvýhodněný balíček" variant="gold" />
          <Badge text="Nové" variant="gold" />
          <Badge text="45–120 min" variant="subtle" />
        </div>
      </section>

      <!-- ══════════════════════════════════════
           CARDS
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="cards">
        <h2 class="sg-section-title">Karty</h2>
        <div class="sg-cards-grid">

          <div>
            <p class="sg-variant-label">Service card</p>
            <Card variant="service">
              <div class="sg-card-icon" aria-hidden="true" set:html={iconSample} />
              <h3 class="sg-card-title">Kosmetická péče</h3>
              <p class="sg-card-text">Specializovaná ošetření s kosmeceutikou Larens pro každý typ pleti.</p>
              <div class="sg-card-meta">
                <Badge text="od 1 100 Kč" variant="gold" />
                <Badge text="60–120 min" variant="subtle" />
              </div>
            </Card>
          </div>

          <div>
            <p class="sg-variant-label">Info card</p>
            <Card variant="info">
              <div class="sg-card-icon" aria-hidden="true" set:html={iconSample} />
              <h3 class="sg-card-title">Příprava pleti</h3>
              <p class="sg-card-text">Balíček 3× kosmetické ošetření pro dokonalou přípravu pleti před svatebním dnem.</p>
              <Badge text="3 500 Kč" variant="gold" />
            </Card>
          </div>

          <div>
            <p class="sg-variant-label">Testimonial card</p>
            <Card variant="testimonial">
              <div class="sg-testimonial-body">
                <p class="sg-testimonial-text">Jana je naprosto skvělá profesionálka. Její holistický přístup a osobní péče mě nadchly.</p>
                <div class="sg-testimonial-author">
                  <div class="sg-testimonial-avatar">M</div>
                  <div>
                    <p style="font-weight: var(--weight-medium); font-size: var(--text-sm);">Markéta</p>
                    <p style="font-size: var(--text-xs); color: var(--color-text-soft);">Klientka salonu</p>
                  </div>
                </div>
              </div>
            </Card>
          </div>

        </div>
      </section>

      <!-- ══════════════════════════════════════
           SERVICE PHOTO CARD
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="photo-cards">
        <h2 class="sg-section-title">Foto karty — Service Photo Card</h2>
        <p class="sg-variant-label" style="margin-bottom: var(--space-6);">
          Použití: karusel služeb na homepage. Třída <code>.spc</code>. Hover zobrazí popisek.
        </p>

        <div class="sg-photo-cards-demo">

          <!-- Karta 1 — default stav -->
          <div>
            <p class="sg-variant-label">Default</p>
            <div class="spc" style="position:relative;">
              <img src="/images/janeskin-vysetreni-detail.webp" alt="Demo" class="spc__img" loading="lazy" />
              <div class="spc__overlay"></div>
              <span class="spc__badge">Péče o pleť</span>
              <div class="spc__body">
                <p class="spc__desc">Specializovaná ošetření s kosmeceutikou Larens pro každý typ pleti.</p>
                <h3 class="spc__title">Kosmetická péče</h3>
                <div class="spc__meta">
                  <span class="spc__price">od 1 100 Kč</span>
                  <span class="spc__dot"></span>
                  <span class="spc__duration">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    60–120 min
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- Karta 2 — hover stav (forced) -->
          <div>
            <p class="sg-variant-label">Hover (desc viditelný)</p>
            <div class="spc spc--force-hover" style="position:relative;">
              <img src="/images/peel-maska.webp" alt="Demo" class="spc__img" loading="lazy" />
              <div class="spc__overlay"></div>
              <span class="spc__badge">Akné & Peeling</span>
              <div class="spc__body">
                <p class="spc__desc spc__desc--visible">Povrchové chemické peelingy s přírodními peptidy rybího kolagenu. Pleť se zjemní a projasní.</p>
                <h3 class="spc__title">Chemické peelingy</h3>
                <div class="spc__meta">
                  <span class="spc__price">od 1 100 Kč</span>
                  <span class="spc__dot"></span>
                  <span class="spc__duration">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    60 min
                  </span>
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- Tokeny reference -->
        <div class="sg-photo-card-tokens">
          <h3 class="sg-subsection-title">Použité tokeny</h3>
          <ul class="sg-token-list">
            <li><code>--font-heading</code> — název služby</li>
            <li><code>--font-body</code> — badge, popis, meta</li>
            <li><code>--text-3xl</code> — název</li>
            <li><code>--text-xs</code> + <code>letter-spacing 0.1em</code> — badge</li>
            <li><code>--text-base</code> — cena</li>
            <li><code>--text-sm</code> — popis, čas</li>
            <li><code>--color-accent</code> — cena</li>
            <li><code>--color-white</code> — název, čas</li>
            <li><code>--radius-xl</code> — karta</li>
            <li><code>--radius-full</code> — badge</li>
            <li><code>--transition-base</code> — hover efekty</li>
          </ul>
        </div>
      </section>

      <!-- ══════════════════════════════════════
           ŠIPKY KARUSELU
      ═══════════════════════════════════════ -->
      <section class="sg-section" id="carousel-arrows">
        <h2 class="sg-section-title">Šipky karuselu</h2>
        <p class="sg-section-desc">
          Navigační tlačítka karuselu. Absolutně pozicována uvnitř <code>.carousel-outer</code> (position: relative).
          Na mobilu (≤ 768px) se zobrazují centrovaně pod karuselem.
        </p>

        <div class="sg-subsection">
          <p class="sg-subsection-title">Stavy</p>
          <div class="sg-arrow-demo">
            <!-- Default -->
            <div class="sg-arrow-item">
              <button class="sg-arrow" aria-label="Předchozí">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <p class="sg-variant-label">Default</p>
            </div>
            <!-- Hover (forced) -->
            <div class="sg-arrow-item">
              <button class="sg-arrow sg-arrow--hover" aria-label="Další">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
              <p class="sg-variant-label">Hover / Active</p>
            </div>
            <!-- Disabled -->
            <div class="sg-arrow-item">
              <button class="sg-arrow" disabled aria-label="Zakázáno">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <p class="sg-variant-label">Disabled</p>
            </div>
            <!-- Mobile size -->
