</Layout>

<style>
  /* ── Layout ── */
  .sg-wrap {
    min-height: 100vh;
  }

  .sg-page-header {
    background-color: var(--color-text);
    padding-top: calc(72px + var(--space-10));
    padding-bottom: var(--space-10);
  }

  .sg-page-header__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-10);
    flex-wrap: wrap;
  }

  .sg-eyebrow {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    font-weight: var(--weight-medium);
    margin-bottom: var(--space-2);
  }

  .sg-page-title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--weight-medium);
    color: var(--color-white);
    margin-bottom: var(--space-3);
  }

  .sg-page-sub {
    font-size: var(--text-base);
    color: rgba(255,255,255,0.5);
  }

  .sg-toc {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-content: flex-start;
    max-width: 360px;
  }

  .sg-toc a {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    transition: all var(--transition-fast);
  }

  .sg-toc a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .sg-body {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-20);
  }

  /* ── Sections ── */
  .sg-section {
    scroll-margin-top: 90px;
  }

  .sg-section-title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    padding-bottom: var(--space-4);
    border-bottom: 2px solid var(--color-accent-light);
    margin-bottom: var(--space-8);
  }

  .sg-subsection {
    margin-bottom: var(--space-8);
  }

  .sg-subsection-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-soft);
    margin-bottom: var(--space-4);
  }

  .sg-variant-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-soft);
    margin-bottom: var(--space-3);
  }

  .sg-demo-box {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-10) var(--space-8);
  }

  /* ── Colors ── */
  .sg-colors {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-4);
  }

  .sg-color__swatch {
    height: 80px;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-2);
  }

  .sg-color__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .sg-color__token {
    font-family: monospace;
    font-size: 10px;
    color: var(--color-text-soft);
    word-break: break-all;
    margin-top: 2px;
  }

  .sg-color__hex {
    font-family: monospace;
    font-size: var(--text-xs);
    color: var(--color-text-soft);
    margin-top: 2px;
  }

  /* ── Fonts ── */
  .sg-fonts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .sg-font-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .sg-font-card__name {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-1);
  }

  .sg-font-card__token {
    font-family: monospace;
    font-size: var(--text-xs);
    color: var(--color-text-soft);
    margin-bottom: var(--space-4);
  }

  .sg-font-card__sample--heading {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--weight-medium);
    line-height: 1.5;
    color: var(--color-text);
  }

  .sg-font-card__sample--body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--color-text);
  }

  /* ── Type headings ── */
  .sg-type-headings {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .sg-type-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-6);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .sg-type-meta {
    font-family: monospace;
    font-size: var(--text-xs);
    color: var(--color-text-soft);
    white-space: nowrap;
    min-width: 160px;
    flex-shrink: 0;
  }

  .sg-demo-h1 { font-size: var(--text-5xl); font-family: var(--font-heading); font-weight: var(--weight-medium); color: var(--color-text); margin: 0; }
  .sg-demo-h2 { font-size: var(--text-4xl); font-family: var(--font-heading); font-weight: var(--weight-medium); color: var(--color-text); margin: 0; }
  .sg-demo-h3 { font-size: var(--text-3xl); font-family: var(--font-heading); font-weight: var(--weight-medium); color: var(--color-text); margin: 0; }
  .sg-demo-h4 { font-size: var(--text-2xl); font-family: var(--font-heading); font-weight: var(--weight-medium); color: var(--color-text); margin: 0; }

  /* ── Type scale ── */
  .sg-type-scale {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .sg-type-scale-row {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Type utils ── */
  .sg-type-utils {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  /* ── Spacing ── */
  .sg-spacing {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sg-spacing-row {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .sg-spacing-token {
    font-family: monospace;
    font-size: var(--text-xs);
    color: var(--color-text-soft);
    min-width: 120px;
  }

  .sg-spacing-val {
    font-family: monospace;
    font-size: var(--text-xs);
    color: var(--color-accent-hover);
    min-width: 48px;
  }

  .sg-spacing-bar {
    height: 20px;
    background-color: var(--color-accent-light);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-accent);
  }

  /* ── Radius ── */
  .sg-radii {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    align-items: flex-end;
  }

  .sg-radius-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .sg-radius-box {
    width: 80px;
    height: 80px;
    background-color: var(--color-accent-light);
    border: 2px solid var(--color-accent);
  }

  .sg-radius-token {
    font-family: monospace;
    font-size: 10px;
    color: var(--color-text-soft);
    text-align: center;
  }

  .sg-radius-val {
    font-family: monospace;
    font-size: var(--text-xs);
    color: var(--color-accent-hover);
  }

  /* ── Shadows ── */
  .sg-shadows {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
    align-items: flex-end;
  }

  .sg-shadow-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .sg-shadow-box {
    width: 100px;
    height: 100px;
    background-color: var(--color-white);
    border-radius: var(--radius-lg);
  }

  .sg-shadow-token {
    font-family: monospace;
    font-size: 10px;
    color: var(--color-text-soft);
    text-align: center;
  }

  .sg-shadow-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-accent-hover);
  }

  /* ── Buttons row ── */
  .sg-row {
    display: flex;
    gap: var(--space-4);
  }
  .sg-row--wrap { flex-wrap: wrap; }
  .sg-row--baseline { align-items: flex-end; }

  /* ── Cards ── */
  .sg-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .sg-card-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-accent-light);
    border-radius: var(--radius-md);
    color: var(--color-accent-hover);
  }

  .sg-card-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .sg-card-text {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    line-height: 1.65;
    flex: 1;
  }

  .sg-card-meta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: auto;
  }

  .sg-testimonial-body {
    padding-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .sg-testimonial-text {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    line-height: 1.6;
  }

