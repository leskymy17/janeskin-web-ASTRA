---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  breadcrumb?: { label: string; href: string }[];
}

const { label, title, subtitle, breadcrumb } = Astro.props;
---

<section class="page-header" aria-label="Záhlaví stránky">
  <div class="page-header__inner container">
    {breadcrumb && (
      <nav class="page-header__breadcrumb" aria-label="Drobečková navigace">
        <ol class="page-header__breadcrumb-list" role="list">
          <li>
            <a href="/" class="page-header__breadcrumb-link">Úvod</a>
          </li>
          {breadcrumb.map((crumb, i) => (
            <li>
              <span class="page-header__breadcrumb-sep" aria-hidden="true">/</span>
              {i === breadcrumb.length - 1 ? (
                <span aria-current="page">{crumb.label}</span>
              ) : (
                <a href={crumb.href} class="page-header__breadcrumb-link">{crumb.label}</a>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}

    {label && <p class="page-header__label">{label}</p>}
    <h1 class="page-header__title">{title}</h1>
    {subtitle && <p class="page-header__subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .page-header {
    background-color: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    padding-top: calc(72px + var(--space-12));
    padding-bottom: var(--space-12);
  }

  .page-header__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .page-header__breadcrumb {
    margin-bottom: var(--space-2);
  }

  .page-header__breadcrumb-list {
    list-style: none;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  .page-header__breadcrumb-list li {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .page-header__breadcrumb-link {
    color: var(--color-text-soft);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .page-header__breadcrumb-link:hover {
    color: var(--color-accent);
  }

  .page-header__breadcrumb-sep {
    color: var(--color-border);
  }

  .page-header__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .page-header__title {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.1;
  }

  .page-header__subtitle {
    font-size: var(--text-xl);
    color: var(--color-text-soft);
    line-height: 1.6;
    max-width: 640px;
  }

  @media (max-width: 768px) {
    .page-header {
      padding-top: calc(72px + var(--space-8));
      padding-bottom: var(--space-8);
    }
    .page-header__title {
      font-size: var(--text-4xl);
    }
    .page-header__subtitle {
      font-size: var(--text-lg);
    }
  }
</style>
