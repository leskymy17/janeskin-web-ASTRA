---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  breadcrumb?: { label: string; href: string }[];
  image?: string;
}

const { label, title, subtitle, breadcrumb, image } = Astro.props;
---

<section class={`page-header${image ? ' page-header--photo' : ''}`} aria-label="Záhlaví stránky">
  {image && (
    <div class="page-header__bg" aria-hidden="true">
      <img
        src={image}
        alt=""
        class="page-header__bg-img"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="600"
      />
      <div class="page-header__overlay"></div>
    </div>
  )}

  <div class="page-header__inner container">
    {breadcrumb && (
      <nav class="page-header__breadcrumb" aria-label="Drobečková navigace">
        <ol class="page-header__breadcrumb-list" role="list">
          <li>
            <a href="/" class="page-header__breadcrumb-link">Úvod</a>
          </li>
          {breadcrumb.map((crumb, i) => (
            <li>
              <span class="page-header__breadcrumb-sep" aria-hidden="true">/</span>
              {i === breadcrumb.length - 1 ? (
                <span aria-current="page">{crumb.label}</span>
              ) : (
                <a href={crumb.href} class="page-header__breadcrumb-link">{crumb.label}</a>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}

    {label && <p class="page-header__label">{label}</p>}
    <h1 class="page-header__title">{title}</h1>
    {subtitle && <p class="page-header__subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .page-header {
    position: relative;
    background-color: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    padding-top: calc(72px + var(--space-12));
    padding-bottom: var(--space-12);
  }

  /* ── Photo variant ── */
  .page-header--photo {
    background-color: transparent;
    border-bottom: none;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
  }

  .page-header__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .page-header__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    display: block;
  }

  .page-header__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20, 14, 10, 0.30) 0%,
      rgba(20, 14, 10, 0.55) 55%,
      rgba(20, 14, 10, 0.80) 100%
    );
  }

  /* ── Inner ── */
  .page-header__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: 100%;
  }

  /* ── Breadcrumb ── */
  .page-header__breadcrumb {
    margin-bottom: var(--space-2);
  }

  .page-header__breadcrumb-list {
    list-style: none;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  .page-header--photo .page-header__breadcrumb-list {
    color: rgba(255, 255, 255, 0.65);
  }

  .page-header__breadcrumb-list li {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .page-header__breadcrumb-link {
    color: var(--color-text-soft);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .page-header--photo .page-header__breadcrumb-link {
    color: rgba(255, 255, 255, 0.65);
  }

  .page-header__breadcrumb-link:hover {
    color: var(--color-accent);
  }

  .page-header__breadcrumb-sep {
    color: var(--color-border);
  }

  .page-header--photo .page-header__breadcrumb-sep {
    color: rgba(255, 255, 255, 0.3);
  }

  /* ── Text ── */
  .page-header__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .page-header__title {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: 1.1;
  }

  .page-header--photo .page-header__title {
    color: var(--color-white);
  }

  .page-header__subtitle {
    font-size: var(--text-xl);
    color: var(--color-text-soft);
    line-height: 1.6;
    max-width: 640px;
  }

  .page-header--photo .page-header__subtitle {
    color: rgba(255, 255, 255, 0.80);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .page-header {
      padding-top: calc(72px + var(--space-8));
      padding-bottom: var(--space-8);
    }
    .page-header--photo {
      min-height: 380px;
    }
    .page-header__title {
      font-size: var(--text-4xl);
    }
    .page-header__subtitle {
      font-size: var(--text-lg);
    }
  }
</style>
