---
import Button from '../ui/Button.astro';

const trustItems = [
  '12+ let zkušeností',
  'Kosmeceutika Larens',
  'Certifikovaná vizážistka',
  'Osobní přístup',
];
---

<section class="hero" aria-label="Uvítací sekce">
  <div class="hero__bg">
    <img
      src="/images/hero-hp.webp"
      alt="Kosmetické ošetření v salonu JANESKIN"
      class="hero__img"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1406"
      height="938"
    />
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero__content">
    <div class="hero__text">
      <p class="hero__label" data-animate data-delay="100">Kosmetický salon · Dolní Lutyně</p>
      <h1 class="hero__title" data-animate data-delay="200">Péče o Vaši pleť<br />s láskou, odborností<br />a vědou</h1>
      <p class="hero__subtitle" data-animate data-delay="300">
        Osobní přístup, kosmeceutická péče Larens a více než 15 specializovaných ošetření
        pro každý typ pleti. Pro ženy i muže, bez rozdílu věku.
      </p>
      <div class="hero__actions" data-animate data-delay="400">
        <Button href="https://noona.app/cs/janeskinsalonjanaszymikova" variant="primary" size="lg" target="_blank" rel="noopener noreferrer">Objednat se</Button>
        <Button href="/sluzby" variant="outline" size="lg">Prohlédnout služby</Button>
      </div>
    </div>
  </div>

  <div class="hero__trust">
    <ul class="hero__trust-inner" role="list">
      {trustItems.map(item => (
        <li class="hero__trust-item">
          <svg class="hero__trust-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 83vh;
    display: flex;
    flex-direction: column;
  }

  /* Background */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgba(0, 0, 0, 0.55) 0%,
        rgba(0, 0, 0, 0.10) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.25) 0%,
        rgba(0, 0, 0, 0.50) 100%
      );
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 1;
    flex: 1;
    padding: 120px var(--space-6) var(--space-16);
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .hero__text {
    max-width: 700px;
    text-align: left;
  }

  .hero__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    font-weight: var(--weight-regular);
    line-height: 1.2;
    color: var(--color-white);
    margin-bottom: var(--space-6);
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.65;
    max-width: 580px;
    margin-bottom: var(--space-8);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    justify-content: flex-start;
  }

  /* Trust strip */
  .hero__trust {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero__trust-inner {
    list-style: none;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-6) var(--space-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-12);
    align-items: center;
    justify-content: center;
  }

  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.85);
    font-weight: var(--weight-medium);
    white-space: nowrap;
  }

  .hero__trust-check {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: var(--text-4xl);
    }
    .hero__subtitle {
      font-size: var(--text-base);
    }
    .hero__content {
      padding-top: 100px;
      padding-bottom: var(--space-10);
      align-items: center;
    }
    .hero__trust-inner {
      gap: var(--space-5);
      padding: var(--space-5) var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .hero__trust-inner {
      gap: var(--space-4);
    }
    .hero__actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
