---
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';

const features = [
  'Tištěný poukaz v luxusní obálce',
  'Elektronický poukaz emailem obratem',
  'Hodnota 1 000 / 1 500 / 2 000 Kč',
  'Platnost 6 měsíců od zakoupení',
];
---

<section class="gift-cards section section--alt" id="darkove-poukazy" aria-label="Dárkové poukazy">
  <div class="container">
    <div class="gift-cards__layout" data-animate>
      <div class="gift-cards__left">
        <SectionHeading
          label="Dárkové poukazy"
          title="Darujte krásu a relaxaci"
          subtitle="Dárkový poukaz na kosmetické ošetření, masáž, laminaci nebo vizáž — ideální dárek pro každou příležitost."
          align="left"
        />

        <ul class="gift-cards__features" role="list">
          {features.map(f => (
            <li class="gift-cards__feature">
              <span class="gift-cards__check" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="gift-cards__feature-title">{f}</span>
            </li>
          ))}
        </ul>

        <div class="gift-cards__btn">
          <Button href="#kontakt" variant="primary" size="md">Objednat poukaz →</Button>
        </div>
      </div>

      <div class="gift-cards__visual">
        <img
          src="/images/poukazy-janeskin.webp"
          alt="Dárkové poukazy JANESKIN"
          class="gift-cards__img"
          loading="lazy"
          decoding="async"
          width="900"
          height="900"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .gift-cards__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .gift-cards__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .gift-cards__left :global(.section-heading) {
    margin-bottom: 0;
  }

  .gift-cards__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .gift-cards__feature {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .gift-cards__check {
    width: 32px;
    height: 32px;
    border-radius: 100px;
    background-color: var(--color-accent-light);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .gift-cards__feature-title {
    font-size: var(--text-base);
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .gift-cards__visual {
    display: flex;
    align-items: center;
  }

  .gift-cards__img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    display: block;
  }

  @media (max-width: 768px) {
    .gift-cards__layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .gift-cards__visual {
      order: -1;
    }
  }
</style>
