---
import Button from '../ui/Button.astro';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section class="about section" id="o-mne" aria-label="O mně">
  <div class="about__inner container">
    <div class="about__image" data-animate>
      <img
        src="/images/janeskin-fotka-profil.jpg"
        alt="Jana Szymiková — majitelka salonu JANESKIN"
        class="about__img"
        loading="lazy"
        decoding="async"
        width="800"
        height="1067"
      />
      <div class="about__image-badge">
        <span class="about__years">15+</span>
        <span class="about__years-label">let zkušeností</span>
      </div>
    </div>

    <div class="about__content" data-animate data-delay="200">
      <SectionHeading
        label="O mně"
        title="Jana Szymiková"
        align="left"
      />
      <div class="about__text">
        <p>
          Jmenuji se Jana a kosmetika je moje vášeň. Svůj salon jsem vybudovala
          s jedinou myšlenkou — abyste se u mě cítili příjemně, v bezpečí
          a v dobrých rukou.
        </p>
        <p>
          Každého klienta vnímám jako celek. Nejde mi jen o vzhled, ale o to,
          abyste odcházeli s pocitem, že jste si dopřáli něco skutečně dobrého.
        </p>
        <p>
          Pravidelně se školím v oblasti kosmeceutiky, moderních ošetření
          i dekorativní kosmetiky, abych vám mohla nabídnout to nejlepší
          ze světa vědy i přírody.
        </p>
      </div>
      <Button href="/o-mne" variant="text" size="md">Více o mně</Button>
    </div>
  </div>
</section>

<style>
  .about__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  /* Image column */
  .about__image {
    position: relative;
  }

  .about__img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-lg);
    display: block;
  }

  .about__image-badge {
    position: absolute;
    bottom: var(--space-6);
    right: calc(-1 * var(--space-6));
    background-color: var(--color-accent);
    color: var(--color-text);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: var(--shadow-md);
  }

  .about__years {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--weight-semibold);
    line-height: 1;
  }

  .about__years-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  /* Text column */
  .about__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about__text p {
    font-size: var(--text-lg);
    color: var(--color-text-soft);
    line-height: 1.7;
  }

  @media (max-width: 1024px) {
    .about__inner {
      gap: var(--space-10);
    }
    .about__image-badge {
      right: calc(-1 * var(--space-4));
    }
  }

  @media (max-width: 768px) {
    .about__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .about__image {
      max-width: 360px;
      margin: 0 auto;
    }
    .about__image-badge {
      right: 0;
      bottom: var(--space-4);
    }
    .about__text p {
      font-size: var(--text-base);
    }
  }
</style>
