---
import SectionHeading from '../ui/SectionHeading.astro';
import InfoBox from '../ui/InfoBox.astro';
import Button from '../ui/Button.astro';

const benefits = [
  {
    title: 'Vědecky ověřené',
    text: 'Výsledky potvrzeny vědeckým výzkumem, vysoké koncentrace aktivních látek.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>`,
  },
  {
    title: 'Přírodní složení',
    text: 'Přírodní peptidy rybího kolagenu. Žádné parabeny, silikony ani syntetické konzervanty.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c4.97 0 9-3.58 9-8s-4.03-8-9-8c-1.5 0-2.91.36-4.14.99"/><path d="M3.34 14A9.97 9.97 0 0 1 3 12c0-1.5.33-2.91.92-4.18"/><path d="M12 6V2"/><path d="M6 12H2"/></svg>`,
  },
  {
    title: 'Pro všechny typy pleti',
    text: 'Liposomální technologie pro maximální vstřebatelnost — citlivá, mastná i zralá pleť.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
];
---

<section class="larens section" id="larens" aria-label="Kosmeceutika Larens">
  <div class="larens__inner container">
    <div class="larens__content" data-animate>
      <SectionHeading
        label="Kosmeceutika"
        title="Proč Larens?"
        align="left"
      />

      <p class="larens__text">
        V salonu pracuji výhradně s kosmeceutikou Larens — přípravky, které stojí
        na rozhraní kosmetiky a farmacie. Vysoké koncentrace aktivních látek,
        liposomální technologie, přírodní peptidy rybího kolagenu — a žádné
        parabeny, silikony ani syntetické konzervanty. Výsledky potvrzeny
        vědeckým výzkumem.
      </p>

      <ul class="larens__benefits" role="list">
        {benefits.map(benefit => (
          <li>
            <InfoBox icon={benefit.icon} title={benefit.title} text={benefit.text} />
          </li>
        ))}
      </ul>

      <Button href="/sluzby#larens" variant="text" size="md">Zjistit více o Larens</Button>
    </div>

    <div class="larens__visual" aria-hidden="true" data-animate data-delay="200">
      <img
        src="/images/detail_larens-50-ml-biopeptide.jpg"
        alt="Larens 50ml Biopeptide — přípravky v salonu JANESKIN"
        class="larens__img"
        loading="lazy"
        decoding="async"
        width="800"
        height="1067"
      />
    </div>
  </div>
</section>

<style>
  .larens__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .larens__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .larens__content :global(.section-heading) {
    margin-bottom: 32px;
  }

  .larens__text {
    font-size: var(--text-lg);
    color: var(--color-text-soft);
    line-height: 1.7;
  }

  .larens__benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* Visual */
  .larens__visual {
    height: 100%;
  }

  .larens__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-lg);
    max-height: 600px;
  }

  @media (max-width: 1024px) {
    .larens__inner {
      gap: var(--space-10);
    }
  }

  @media (max-width: 768px) {
    .larens__inner {
      grid-template-columns: 1fr;
    }
    .larens__visual {
      display: none;
    }
    .larens__text {
      font-size: var(--text-base);
    }
  }
</style>
