---
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

const packages = [
  {
    title: 'Příprava pleti',
    description: 'Zvýhodněný balíček 3× kosmetické ošetření pro dokonalou přípravu pleti před svatebním dnem.',
    price: '3 500 Kč',
    note: 'Úspora oproti individuálním ošetřením',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Svatební vizáž',
    description: 'Svatební líčení včetně zkoušky — výsledek, který vydrží celý den a nohu na úrovni.',
    price: 'od 3 500 Kč',
    note: 'Včetně zkoušky líčení',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  },
  {
    title: 'Kompletní vizáž',
    description: 'Make-up i účes v jednom — kompletní proměna pro Váš největší den.',
    price: 'od 4 500 Kč',
    note: 'Make-up + účes',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
];
---

<section class="brides section" id="pro-nevesty" aria-label="Služby pro nevěsty">
  <div class="brides__backdrop" aria-hidden="true"></div>

  <div class="container">
    <SectionHeading
      label="Pro nevěsty"
      title="Váš svatební den začíná zdravím a krásou"
      subtitle="Připravím Vaši pleť na velký den od základu — od kosmetických ošetření až po svatební líčení a účes, které vydrží do rána."
    />

    <ul class="brides__grid" role="list" data-animate>
      {packages.map(pkg => (
        <li>
          <Card variant="info">
            <div class="bride-card__icon" aria-hidden="true" set:html={pkg.icon} />
            <h3 class="bride-card__title">{pkg.title}</h3>
            <p class="bride-card__desc">{pkg.description}</p>
            <div class="bride-card__footer">
              <Badge text={pkg.price} variant="gold" />
              <span class="bride-card__note">{pkg.note}</span>
            </div>
          </Card>
        </li>
      ))}
    </ul>

    <p class="brides__tip">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Ideálně začněte 3 měsíce před svatbou.
    </p>

    <div class="brides__cta">
      <Button href="/pro-nevesty" variant="primary" size="md">Více o svatebních službách</Button>
      <Button href="#kontakt" variant="outline" size="md">Nezávazná konzultace</Button>
    </div>
  </div>
</section>

<style>
  .brides {
    position: relative;
    background-color: var(--color-text);
    color: var(--color-white);
    overflow: hidden;
  }

  .brides__backdrop {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 70% 50%,
      rgba(201, 169, 110, 0.12) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  /* Override SectionHeading colors for dark bg */
  .brides :global(.section-heading__title) {
    color: var(--color-white);
  }
  .brides :global(.section-heading__subtitle) {
    color: rgba(255, 255, 255, 0.7);
  }

  .brides__grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  /* Card overrides for dark section */
  .brides :global(.card--info) {
    background-color: rgba(255, 255, 255, 0.06);
    border-color: rgba(201, 169, 110, 0.25);
  }
  .brides :global(.card--info:hover) {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .bride-card__icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(201, 169, 110, 0.15);
    border-radius: var(--radius-md);
    color: var(--color-accent);
  }

  .bride-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-regular);
    color: var(--color-white);
    line-height: 1.2;
  }

  .bride-card__desc {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.65;
    flex: 1;
  }

  .bride-card__footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-2);
  }

  .bride-card__note {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.04em;
  }

  .brides__tip {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-accent);
    margin-bottom: var(--space-8);
    justify-content: center;
  }

  .brides__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }

  /* Outline button on dark bg */
  .brides :global(.btn--outline) {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .brides :global(.btn--outline:hover) {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: var(--color-white);
  }

  @media (max-width: 1024px) {
    .brides__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .brides__grid {
      grid-template-columns: 1fr;
    }
    .brides__cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
