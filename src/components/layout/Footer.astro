---
import Button from '../ui/Button.astro';

const navLinks = [
  { label: 'Služby',      href: '/sluzby' },
  { label: 'O mně',       href: '/#o-mne' },
  { label: 'Ceník',       href: '/cenik' },
  { label: 'Pro nevěsty', href: '/pro-nevesty' },
  { label: 'Kontakt',     href: '/kontakt' },
];

const legalLinks = [
  { label: 'Obchodní podmínky', href: '/obchodni-podminky' },
  { label: 'Reklamační řád',    href: '/reklamacni-rad' },
  { label: 'GDPR',              href: '/gdpr' },
];

const year = 2026;
---

<!-- ── CTA sekce ── -->
<section class="footer-cta" aria-label="Výzva k akci">
  <div class="footer-cta__bg">
    <img
      src="/images/footer-bg.webp"
      alt=""
      class="footer-cta__img"
      loading="lazy"
      decoding="async"
      aria-hidden="true"
      width="1920"
      height="800"
    />
    <div class="footer-cta__overlay" aria-hidden="true"></div>
  </div>

  <div class="footer-cta__inner" data-animate>
    <p class="footer-cta__label">Začněte dnes</p>
    <h2 class="footer-cta__title">Máte zájem o některou<br />ze služeb?</h2>
    <p class="footer-cta__subtitle">
      Rezervujte si termín online nebo nám zavolejte.<br />
      Rádi vám poradíme s výběrem ošetření.
    </p>
    <div class="footer-cta__actions">
      <Button href="https://noona.app/cs/janeskinsalonjanaszymikova" variant="primary" size="lg" target="_blank" rel="noopener noreferrer">Objednat se online</Button>
      <Button href="tel:+420000000000" variant="outline" size="lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6.29 6.29l1.27-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Zavolat
      </Button>
    </div>
  </div>
</section>

<!-- ── Footer ── -->
<footer class="footer" role="contentinfo">
  <div class="footer__top container">

    <!-- Brand column -->
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="JANESKIN — přejít na úvod">
        <img
          src="/images/logo-janeskin.svg"
          alt="JANESKIN"
          class="footer__logo-img"
          width="160"
          height="30"
          loading="lazy"
          decoding="async"
        />
      </a>
      <p class="footer__tagline">
        Profesionální kosmetická péče s kosmeceutikou Larens.<br />
        Dolní Lutyně — Jana Szymiková
      </p>
      <div class="footer__social" aria-label="Sociální sítě">
        <a
          href="https://www.instagram.com/"
          class="footer__social-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="JANESKIN na Instagramu"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/"
          class="footer__social-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="JANESKIN na Facebooku"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Navigation column -->
    <nav class="footer__nav" aria-label="Navigace ve footeru">
      <h3 class="footer__col-title">Navigace</h3>
      <ul class="footer__nav-list" role="list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="footer__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Contact column -->
    <div class="footer__contact">
      <h3 class="footer__col-title">Kontakt</h3>
      <ul class="footer__contact-list" role="list">
        <li>
          <a href="tel:+420000000000" class="footer__link footer__link--icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6.29 6.29l1.27-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +420 000 000 000
          </a>
        </li>
        <li>
          <a href="mailto:info@janeskin.cz" class="footer__link footer__link--icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            info@janeskin.cz
          </a>
        </li>
        <li class="footer__address">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Dolní Lutyně</span>
        </li>
      </ul>
    </div>

    <!-- Opening hours column -->
    <div class="footer__hours">
      <h3 class="footer__col-title">Otevírací doba</h3>
      <dl class="footer__hours-list">
        <div class="footer__hours-row">
          <dt>Po–Pá</dt>
          <dd>dle objednání</dd>
        </div>
        <div class="footer__hours-row">
          <dt>Sobota</dt>
          <dd>dle objednání</dd>
        </div>
        <div class="footer__hours-row">
          <dt>Neděle</dt>
          <dd>dle domluvy</dd>
        </div>
      </dl>
      <a href="https://noona.app/cs/janeskinsalonjanaszymikova" class="footer__cta" target="_blank" rel="noopener noreferrer">Objednat se</a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="footer__bottom-inner container">
      <p class="footer__copy">
        &copy; {year} JANESKIN — Salon Jana Szymiková
      </p>
      <ul class="footer__legal" role="list">
        {legalLinks.map(link => (
          <li>
            <a href={link.href} class="footer__legal-link">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  /* ══════════════════════════════════
     CTA sekce
  ══════════════════════════════════ */
  .footer-cta {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-cta__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .footer-cta__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .footer-cta__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(44, 36, 32, 0.45) 0%,
      rgba(44, 36, 32, 0.40) 40%,
      rgba(44, 36, 32, 0.80) 72%,
      #2C2420 100%
    );
  }

  .footer-cta__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-20) var(--space-6);
    max-width: 760px;
    margin: 0 auto;
    width: 100%;
  }

  .footer-cta__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .footer-cta__title {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    font-weight: var(--weight-regular);
    color: var(--color-white);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }

  .footer-cta__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--weight-regular);
    color: rgba(255, 255, 255, 0.8);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-10);
  }

  .footer-cta__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ══════════════════════════════════
     Footer
  ══════════════════════════════════ */
  .footer {
    background-color: var(--color-text);
    color: var(--color-white);
  }

  /* ── Top grid ── */
  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-10);
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  /* ── Brand ── */
  .footer__logo {
    display: inline-flex;
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .footer__logo-img {
    width: 160px;
    height: auto;
    display: block;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    transition: opacity var(--transition-fast), filter var(--transition-fast);
  }

  .footer__logo:hover .footer__logo-img {
    opacity: 1;
    filter: brightness(0) saturate(100%) invert(68%) sepia(40%) saturate(400%) hue-rotate(5deg) brightness(95%);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
    margin-bottom: var(--space-6);
  }

  .footer__social {
    display: flex;
    gap: var(--space-3);
  }

  .footer__social-link {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .footer__social-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background-color: rgba(201, 169, 110, 0.08);
  }

  /* ── Column titles ── */
  .footer__col-title {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: var(--space-5);
  }

  /* ── Nav list ── */
  .footer__nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color var(--transition-fast);
    line-height: 1.8;
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__link--icon {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* ── Contact ── */
  .footer__contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__address {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.65);
  }

  .footer__address svg {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  /* ── Hours ── */
  .footer__hours-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .footer__hours-row {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-sm);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__hours-row dt {
    color: rgba(255, 255, 255, 0.65);
  }

  .footer__hours-row dd {
    color: rgba(255, 255, 255, 0.45);
    font-style: normal;
  }

  .footer__cta {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    background-color: var(--color-accent);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-4);
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .footer__cta:hover {
    background-color: var(--color-accent-hover);
    color: var(--color-text);
  }

  /* ── Bottom bar ── */
  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.35);
  }

  .footer__legal {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer__legal-link {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__legal-link:hover {
    color: var(--color-accent);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .footer-cta {
      min-height: 480px;
    }
    .footer-cta__title {
      font-size: var(--text-4xl);
    }
    .footer-cta__subtitle {
      font-size: var(--text-base);
    }
  }

  @media (max-width: 640px) {
    .footer__top {
      grid-template-columns: 1fr;
      padding-top: var(--space-10);
      padding-bottom: var(--space-10);
    }
    .footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .footer-cta__title {
      font-size: var(--text-3xl);
    }
    .footer-cta__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }

</style>
