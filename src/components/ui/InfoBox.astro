---
interface Props {
  icon?: string;
  title: string;
  text?: string;
}

const { icon, title, text } = Astro.props;
---

<div class="infobox">
  {icon && (
    <div class="infobox__icon" aria-hidden="true" set:html={icon} />
  )}
  <div class="infobox__body">
    <p class="infobox__title">{title}</p>
    {text && <p class="infobox__text">{text}</p>}
  </div>
</div>

<style>
  .infobox {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .infobox__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-accent-light);
    border-radius: 100px;
    color: var(--color-accent-hover);
  }

  .infobox__icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .infobox__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .infobox__title {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    line-height: 1.3;
  }

  .infobox__text {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    line-height: 1.55;
  }
</style>
