---
interface Props {
  variant?: 'service' | 'info' | 'testimonial';
}

const { variant = 'service' } = Astro.props;
---

<article class={`card card--${variant}`}>
  <slot />
</article>

<style>
  .card {
    background-color: var(--color-white);
    border-radius: var(--radius-lg);
    transition: transform var(--transition-base);
  }

  .card:hover {
    transform: scale(1.02);
  }

  /* --- Service card --- */
  .card--service {
    padding: var(--space-6) var(--space-6) var(--space-8);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* --- Info card --- */
  .card--info {
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* --- Testimonial card --- */
  .card--testimonial {
    padding: var(--space-8);
    border: 1px solid var(--color-accent-light);
    position: relative;
  }
  .card--testimonial::before {
    content: '\201C';
    font-family: var(--font-heading);
    font-size: 5rem;
    line-height: 1;
    color: var(--color-accent-light);
    position: absolute;
    top: var(--space-4);
    left: var(--space-6);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .card--service,
    .card--info {
      padding: var(--space-5);
    }
    .card--testimonial {
      padding: var(--space-6);
    }
  }
</style>
